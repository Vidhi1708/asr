#include <iostream>
using namespace std;

int main() {
    int n, reversedNumber = 0, remainder;
    
    cout << "Enter a number: ";
    cin >> n;
    
    int originalNumber = n; // store original number

    while (n != 0) {
        remainder = n % 10;               // get last digit
        reversedNumber = reversedNumber * 10 + remainder; // append digit
        n /= 10;                          // remove last digit
    }

    cout << "Reversed number of " << originalNumber << " is " << reversedNumber;

    return 0;
}
