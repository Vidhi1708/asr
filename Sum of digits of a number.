#include <iostream>
using namespace std;

int main() {
    int n, sum = 0, remainder;

    cout << "Enter a number: ";
    cin >> n;

    int originalNumber = n; // store original number

    // Calculate sum of digits
    while (n != 0) {
        remainder = n % 10;  // get last digit
        sum += remainder;    // add it to sum
        n /= 10;             // remove last digit
    }

    cout << "Sum of digits of " << originalNumber << " is " << sum;

    return 0;
}
